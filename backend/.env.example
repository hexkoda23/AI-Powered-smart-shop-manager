# Copy this file to .env and fill in your values.

# Local development: SQLite needs no extra setup.
DATABASE_URL=sqlite:///./shop.db

# Railway Postgres: Railway sets DATABASE_URL automatically for deployed services.
# Use DATABASE_PUBLIC_URL if you need to connect from your laptop.
# DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Groq AI key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
